<MudCard Elevation="3" Class="rounded-xl game-card" Style="height:100%; cursor:pointer;"
         @onclick="@(() => Nav.NavigateTo(Href))">
    <MudCardContent>
        <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-4">
            <MudAvatar Style="@($"background-color:{Color}22; width:64px; height:64px;")">
                <MudIcon Icon="@Icon" Style="@($"color:{Color}; font-size:2rem;")" />
            </MudAvatar>
            <MudText Typo="Typo.h6" Align="Align.Center">@Title</MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary">
                @Description
            </MudText>
        </MudStack>
    </MudCardContent>
    <MudCardActions Class="justify-center pb-4">
        <MudButton Variant="Variant.Outlined"
                   Style="@($"color:{Color}; border-color:{Color};")"
                   StartIcon="@Icons.Material.Filled.PlayArrow">
            Play
        </MudButton>
    </MudCardActions>
</MudCard>
