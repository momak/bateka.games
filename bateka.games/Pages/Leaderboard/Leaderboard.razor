@page "/leaderboard"
@using bateka.games.Pages.Memory
@layout MainLayout

<PageTitle>Leaderboard — GameHub</PageTitle>

<MudStack Spacing="5">

    <MudText Typo="Typo.h4" Align="Align.Center" Color="Color.Primary">
        🏆 Leaderboard
    </MudText>

    <!-- Personal Best Summary -->
    <MudPaper Elevation="3" Class="pa-5 rounded-xl"
              Style="background: linear-gradient(135deg, var(--mud-palette-primary) 0%, var(--mud-palette-secondary) 100%);">
        <MudText Typo="Typo.overline" Style="color:rgba(255,255,255,0.7);">Personal Bests</MudText>
        <MudGrid Spacing="3" Class="mt-1">
            <MudItem xs="12" sm="4">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Close" Style="color:white;" />
                        <MudText Typo="Typo.subtitle1" Style="color:white; font-family:'Orbitron',sans-serif;">
                            Tic Tac Toe
                        </MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.85);">
                        Win Rate: <strong>@_tttStats?.WinRate%</strong>
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.85);">
                        Wins: <strong>@(_tttStats?.Wins ?? 0)</strong> /
                        Games: <strong>@(_tttStats?.Total ?? 0)</strong>
                    </MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.GridView" Style="color:white;" />
                        <MudText Typo="Typo.subtitle1" Style="color:white; font-family:'Orbitron',sans-serif;">
                            Memory Match
                        </MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.85);">
                        Best: <strong>@(_memoryBestLabel)</strong>
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.85);">
                        Games: <strong>@(_memoryStats?.GamesPlayed ?? 0)</strong>
                    </MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Gamepad" Style="color:white;" />
                        <MudText Typo="Typo.subtitle1" Style="color:white; font-family:'Orbitron',sans-serif;">
                            Snake
                        </MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.85);">
                        High Score: <strong>@(_snakeStats?.HighScore ?? 0)</strong>
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.85);">
                        Longest: <strong>@(_snakeStats?.LongestSnake ?? 0)</strong>
                    </MudText>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- Side by Side Game Stats -->
    <MudGrid Spacing="4">

        <!-- Tic Tac Toe -->
        <MudItem xs="12" md="4">
            <MudCard Elevation="3" Class="rounded-xl" Style="height:100%;">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Primary">
                            <MudIcon Icon="@Icons.Material.Filled.Close" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Style="font-family:'Orbitron',sans-serif;">
                            Tic Tac Toe
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            vs Algorithm
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (_tttStats is null || _tttStats.Total == 0)
                    {
                        <MudText Class="mud-text-secondary" Align="Align.Center">No games played yet.</MudText>
                    }
                    else
                    {
                        <MudStack Spacing="3">
                            <StatRow Label="Games Played" Value="@_tttStats.Total.ToString()" />
                            <StatRow Label="Wins" Value="@_tttStats.Wins.ToString()" Color="Color.Success" />
                            <StatRow Label="Losses" Value="@_tttStats.Losses.ToString()" Color="Color.Error" />
                            <StatRow Label="Draws" Value="@_tttStats.Draws.ToString()" Color="Color.Warning" />
                            <StatRow Label="Win Rate" Value="@($"{_tttStats.WinRate}%")" Color="Color.Primary" />
                            <StatRow Label="Avg Moves / Game" Value="@_tttStats.AvgMoves.ToString()" />
                        </MudStack>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Memory Match -->
        <MudItem xs="12" md="4">
            <MudCard Elevation="3" Class="rounded-xl" Style="height:100%;">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Secondary">
                            <MudIcon Icon="@Icons.Material.Filled.GridView" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Style="font-family:'Orbitron',sans-serif;">
                            Memory Match
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            Best per grid size
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (_memoryStats is null || _memoryStats.GamesPlayed == 0)
                    {
                        <MudText Class="mud-text-secondary" Align="Align.Center">No games played yet.</MudText>
                    }
                    else
                    {
                        <MudStack Spacing="3">
                            <StatRow Label="Games Played" Value="@_memoryStats.GamesPlayed.ToString()" />
                            @foreach (var best in _memoryStats.BestScores.OrderBy(s => s.Pairs))
                            {
                                <MudDivider />
                                <MudText Typo="Typo.overline" Class="mud-text-secondary">
                                    @best.Pairs Pairs
                                </MudText>
                                <StatRow Label="Fewest Moves" Value="@best.Moves.ToString()" Color="Color.Primary" />
                                <StatRow Label="Best Time" Value="@MemoryGame.FormatTime(best.BestTime)" Color="Color.Secondary" />
                            }
                        </MudStack>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Snake -->
        <MudItem xs="12" md="4">
            <MudCard Elevation="3" Class="rounded-xl" Style="height:100%;">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Style="background:#FF6D00;">
                            <MudIcon Icon="@Icons.Material.Filled.Gamepad" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Style="font-family:'Orbitron',sans-serif;">
                            Snake
                        </MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            All-time bests
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (_snakeStats is null || _snakeStats.GamesPlayed == 0)
                    {
                        <MudText Class="mud-text-secondary" Align="Align.Center">No games played yet.</MudText>
                    }
                    else
                    {
                        <MudStack Spacing="3">
                            <StatRow Label="Games Played" Value="@_snakeStats.GamesPlayed.ToString()" />
                            <StatRow Label="High Score" Value="@_snakeStats.HighScore.ToString()" Color="Color.Warning" />
                            <StatRow Label="Longest Snake" Value="@_snakeStats.LongestSnake.ToString()" Color="Color.Success" />
                            <StatRow Label="Average Score" Value="@_snakeStats.AverageScore.ToString()" Color="Color.Primary" />
                        </MudStack>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>

    <!-- Achievements -->
    <MudText Typo="Typo.h5" Class="mt-2">🎖 Achievements</MudText>

    <MudGrid Spacing="3">
        @foreach (var achievement in _achievements)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="@(achievement.Unlocked ? 3 : 1)"
                          Class="pa-4 rounded-xl"
                          Style="@(achievement.Unlocked
                                                                            ? "border: 1px solid var(--mud-palette-warning);"
                                                                            : "opacity: 0.5;")">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudText Style="font-size:2rem;">
                            @(achievement.Unlocked? achievement.Icon: "🔒")
                        </MudText>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.subtitle2">@achievement.Title</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @achievement.Description
                            </MudText>
                            @if (achievement.Unlocked)
                            {
                                <MudChip T="string" Size="Size.Small"
                                         Color="Color.Warning" Class="mt-1"
                                         Icon="@Icons.Material.Filled.CheckCircle">
                                    Unlocked
                                </MudChip>
                            }
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

</MudStack>