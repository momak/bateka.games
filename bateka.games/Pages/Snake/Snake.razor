@page "/game/snake"
@layout MainLayout
@implements IDisposable

<PageTitle>Snake — GameHub</PageTitle>

<MudStack Spacing="3" AlignItems="AlignItems.Center">

    <MudText Typo="Typo.h4" Align="Align.Center" Color="Color.Primary">
        Snake
    </MudText>

    <!-- Stats Bar -->
    <MudPaper Elevation="2" Class="pa-3 rounded-xl" Style="width:100%; max-width:520px;">
        <MudGrid Justify="Justify.Center" Spacing="2">
            <MudItem xs="3">
                <MudStack AlignItems="AlignItems.Center" Spacing="0">
                    <MudText Typo="Typo.h6" Color="Color.Warning">@Stats.HighScore</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">High Score</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="3">
                <MudStack AlignItems="AlignItems.Center" Spacing="0">
                    <MudText Typo="Typo.h6">@Stats.GamesPlayed</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Games Played</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="3">
                <MudStack AlignItems="AlignItems.Center" Spacing="0">
                    <MudText Typo="Typo.h6" Color="Color.Success">@Stats.LongestSnake</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Longest</MudText>
                </MudStack>
            </MudItem>
            <MudItem xs="3">
                <MudStack AlignItems="AlignItems.Center" Spacing="0">
                    <MudText Typo="Typo.h6" Color="Color.Info">@Stats.AverageScore</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Avg Score</MudText>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- In-game HUD -->
    @if (_gameStarted)
    {
        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
            <MudChip T="string" Color="Color.Primary" Icon="@Icons.Material.Filled.Score">
                Score: @_score
            </MudChip>
            <MudChip T="string" Color="Color.Secondary" Icon="@Icons.Material.Filled.Speed">
                Level: @_level
            </MudChip>
            <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.LinearScale">
                Length: @_snake.Count
            </MudChip>
        </MudStack>
    }

    <!-- Canvas -->
    <div class="snake-container" @ref="_containerRef" tabindex="0"
         @onkeydown="OnKeyDown" @onkeydown:preventDefault="true">

        <canvas @ref="_canvasRef"
                width="@(GridSize* CellSize)"
                height="@(GridSize* CellSize)"
                class="snake-canvas">
        </canvas>

        <!-- Overlays -->
        @if (!_gameStarted && !_gameOver)
        {
            <div class="snake-overlay">
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <MudText Typo="Typo.h5" Style="color:white; font-family:'Orbitron',sans-serif;">
                        🐍 Snake
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.7); text-align:center;">
                        Eat food to grow. Don't hit the walls or yourself!
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="StartGame">
                        Start Game
                    </MudButton>
                </MudStack>
            </div>
        }

        @if (_gameOver)
        {
            <div class="snake-overlay">
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <MudText Typo="Typo.h5" Style="color:white; font-family:'Orbitron',sans-serif;">
                        💀 Game Over
                    </MudText>
                    <MudText Typo="Typo.h6" Style="color:white;">Score: @_score</MudText>
                    @if (_isNewHighScore)
                    {
                        <MudChip T="string" Color="Color.Warning"
                                 Icon="@Icons.Material.Filled.EmojiEvents">
                            New High Score!
                        </MudChip>
                    }
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Replay"
                               OnClick="StartGame">
                        Play Again
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Style="color:white; border-color:white;"
                               StartIcon="@Icons.Material.Filled.DeleteForever"
                               OnClick="ResetStats">
                        Reset Stats
                    </MudButton>
                </MudStack>
            </div>
        }

        @if (_paused && _gameStarted && !_gameOver)
        {
            <div class="snake-overlay">
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <MudText Typo="Typo.h5"
                             Style="color:white; font-family:'Orbitron',sans-serif;">
                        ⏸ Paused
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="TogglePause">
                        Resume
                    </MudButton>
                </MudStack>
            </div>
        }
    </div>

    <!-- Controls -->
    @if (_gameStarted && !_gameOver)
    {
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@(_paused ? Icons.Material.Filled.PlayArrow : Icons.Material.Filled.Pause)"
                   OnClick="TogglePause">
            @(_paused ? "Resume" : "Pause")
        </MudButton>
    }

    <!-- D-Pad (shown on touch devices or always visible) -->
    @if (_gameStarted && !_gameOver && _showDPad)
    {
        <div class="dpad">
            <div class="dpad-row">
                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                               Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="@(() => SetDirection(Direction.Up))" />
            </div>
            <div class="dpad-row">
                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowLeft"
                               Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="@(() => SetDirection(Direction.Left))" />
                <div style="width:48px;height:48px;"></div>
                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowRight"
                               Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="@(() => SetDirection(Direction.Right))" />
            </div>
            <div class="dpad-row">
                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                               Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="@(() => SetDirection(Direction.Down))" />
            </div>
        </div>
    }

</MudStack>